<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AWS Cost Report — {{ report_date }}</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background: #f5f7fa; color: #1a1a2e; padding: 32px; }
    .container { max-width: 960px; margin: 0 auto; }
    .header { background: #1a1a2e; color: white; border-radius: 12px; padding: 32px; margin-bottom: 24px; }
    .header h1 { font-size: 24px; font-weight: 600; margin-bottom: 8px; }
    .header p  { color: #a0aec0; font-size: 14px; }
    .cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 24px; }
    .card { background: white; border-radius: 10px; padding: 20px; border: 1px solid #e2e8f0; }
    .card .label { font-size: 12px; color: #718096; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px; }
    .card .value { font-size: 28px; font-weight: 700; color: #1a1a2e; }
    .card .sub   { font-size: 12px; color: #a0aec0; margin-top: 4px; }
    .section { background: white; border-radius: 10px; padding: 24px; margin-bottom: 24px; border: 1px solid #e2e8f0; }
    .section h2 { font-size: 16px; font-weight: 600; margin-bottom: 16px; color: #2d3748; border-bottom: 1px solid #e2e8f0; padding-bottom: 12px; }
    .chart img { width: 100%; border-radius: 8px; }
    table { width: 100%; border-collapse: collapse; font-size: 14px; }
    th { text-align: left; padding: 10px 12px; background: #f7fafc; color: #718096; font-weight: 500; font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 1px solid #e2e8f0; }
    td { padding: 10px 12px; border-bottom: 1px solid #f0f4f8; }
    tr:last-child td { border-bottom: none; }
    .badge { display: inline-block; padding: 2px 10px; border-radius: 20px; font-size: 11px; font-weight: 600; }
    .badge-active  { background: #c6f6d5; color: #276749; }
    .badge-idle    { background: #fef3c7; color: #92400e; }
    .badge-rising  { background: #fed7d7; color: #9b2c2c; }
    .badge-stable  { background: #e2e8f0; color: #4a5568; }
    .spike-row { background: #fff5f5; }
    .footer { text-align: center; font-size: 12px; color: #a0aec0; margin-top: 24px; }
  </style>
</head>
<body>
<div class="container">

  <div class="header">
    <h1>AWS Cloud Cost Report</h1>
    <p>Generated {{ report_date }} &nbsp;|&nbsp; Account {{ account_id }} &nbsp;|&nbsp; Last 90 days</p>
  </div>

  <div class="cards">
    <div class="card">
      <div class="label">Total spend (90d)</div>
      <div class="value">${{ "%.2f"|format(total_cost) }}</div>
      <div class="sub">across {{ service_count }} services</div>
    </div>
    <div class="card">
      <div class="label">Month-end forecast</div>
      <div class="value">${{ "%.4f"|format(prediction.predicted) }}</div>
      <div class="sub">${{ "%.4f"|format(prediction.lower) }} – ${{ "%.4f"|format(prediction.upper) }} (95% CI)</div>
    </div>
    <div class="card">
      <div class="label">Anomalies detected</div>
      <div class="value">{{ spike_count }}</div>
      <div class="sub">cost spikes above threshold</div>
    </div>
  </div>

  <div class="section chart">
    <h2>30-day cost forecast</h2>
    <img src="{{ chart_path }}" alt="Forecast chart">
  </div>

  <div class="section">
    <h2>Service classification</h2>
    <table>
      <thead>
        <tr>
          <th>Service</th>
          <th>Status</th>
          <th>Total cost</th>
          <th>Last 7 days</th>
          <th>Trend</th>
          <th>Last seen</th>